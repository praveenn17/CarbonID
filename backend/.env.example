# ─────────────────────────────────────────────────────────────────────────────
# .env.example  ·  LOCAL DEVELOPMENT (SQLite — no Docker required)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and start coding immediately.
# SQLite is the zero-config local fallback.
# Schema file: prisma/schema.prisma (provider = sqlite)
# ─────────────────────────────────────────────────────────────────────────────

# SQLite connection — path is relative to backend/prisma/
DATABASE_URL="file:./dev.db"

PORT=5000
NODE_ENV="development"

# Change these in any real deployment
JWT_ACCESS_SECRET="local_dev_secret_replace_in_production"
JWT_REFRESH_SECRET="local_dev_refresh_secret_replace_in_production"

# Must match Vite server.port in frontend/vite.config.ts
FRONTEND_URL="http://localhost:3000"

BCRYPT_ROUNDS=10
