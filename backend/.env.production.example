# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example  ·  PRODUCTION (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env on your production server / CI environment.
# Schema file: prisma/schema.production.prisma (provider = postgresql)
#
# Supported PostgreSQL providers:
#   Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#   Neon:       postgresql://[user]:[password]@[host].neon.tech/[db]?sslmode=require
#   Railway:    postgresql://[user]:[password]@[host]:5432/railway
#   Self-host:  postgresql://postgres:postgres@localhost:5432/carbonid
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/carbonid?schema=public"

PORT=5000
NODE_ENV="production"

# Use strong random secrets in production (32+ chars)
JWT_ACCESS_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_STRONG_SECRET"

# Your deployed frontend domain
FRONTEND_URL="https://carbonid.yourdomain.com"

BCRYPT_ROUNDS=12
